{
  "name": "@togglely/sdk-vue",
  "version": "1.2.5",
  "description": "Vue SDK for Togglely - Feature toggles with composables",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvooo/togglely.git",
    "directory": "sdk/vue"
  },
  "homepage": "https://github.com/nuvooo/togglely/tree/main/sdk/vue",
  "bugs": {
    "url": "https://github.com/nuvooo/togglely/issues"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "vue",
    "composables"
  ],
  "author": "Togglely",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@togglely/sdk-core": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.5",
    "vue": "^3.5.0",
    "rollup": "^4.60.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
