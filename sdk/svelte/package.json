{
  "name": "@togglely/sdk-svelte",
  "version": "1.2.5",
  "description": "Svelte SDK for Togglely - Feature toggles with stores",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "svelte": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvooo/togglely.git",
    "directory": "sdk/svelte"
  },
  "homepage": "https://github.com/nuvooo/togglely/tree/main/sdk/svelte",
  "bugs": {
    "url": "https://github.com/nuvooo/togglely/issues"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "svelte",
    "stores"
  ],
  "author": "Togglely",
  "license": "MIT",
  "peerDependencies": {
    "svelte": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@togglely/sdk-core": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "rollup": "^4.60.0",
    "svelte": "^4.0.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
