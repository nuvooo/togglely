{
  "name": "@togglely/sdk-core",
  "version": "1.2.5",
  "description": "Core SDK for Togglely - Framework agnostic feature flag management with offline support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "togglely-pull": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvooo/togglely.git",
    "directory": "sdk/core"
  },
  "homepage": "https://github.com/nuvooo/togglely/tree/main/sdk/core",
  "bugs": {
    "url": "https://github.com/nuvooo/togglely/issues"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest --runInBand",
    "test:integration": "powershell -ExecutionPolicy Bypass -File scripts/test-integration.ps1",
    "test:integration:bash": "bash scripts/test-integration.sh",
    "test:integration:watch": "jest --config jest.integration.config.cjs --watch",
    "test:all": "npm test && npm run test:integration"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "core",
    "offline",
    "multi-tenant"
  ],
  "author": "Togglely",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.60.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
