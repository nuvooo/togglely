{
  "name": "@togglely/sdk-core",
  "version": "1.2.5",
  "description": "Core SDK for Togglely - Framework agnostic feature flag management with offline support",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "bin": {
    "togglely-pull": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest --runInBand",
    "test:integration": "powershell -ExecutionPolicy Bypass -File scripts/test-integration.ps1",
    "test:integration:bash": "bash scripts/test-integration.sh",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "test:all": "npm test && npm run test:integration"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "core",
    "offline",
    "multi-tenant"
  ],
  "author": "Togglely",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.60.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
