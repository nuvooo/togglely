{
  "name": "@togglely/sdk-react",
  "version": "1.2.6",
  "description": "React SDK for Togglely - Feature toggles with hooks",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvooo/togglely.git",
    "directory": "sdk/react"
  },
  "homepage": "https://github.com/nuvooo/togglely/tree/main/sdk/react",
  "bugs": {
    "url": "https://github.com/nuvooo/togglely/issues"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "react",
    "hooks"
  ],
  "author": "Togglely",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@togglely/sdk-core": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.5",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^4.60.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
