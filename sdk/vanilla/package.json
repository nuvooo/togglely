{
  "name": "@togglely/sdk",
  "version": "1.2.6",
  "description": "Vanilla JavaScript SDK for Togglely - Feature toggles for any framework",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "browser": "dist/index.umd.min.js",
  "unpkg": "dist/index.umd.min.js",
  "jsdelivr": "dist/index.umd.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.esm.js"
    },
    "./umd": "./dist/index.umd.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvooo/togglely.git",
    "directory": "sdk/vanilla"
  },
  "homepage": "https://github.com/nuvooo/togglely/tree/main/sdk/vanilla",
  "bugs": {
    "url": "https://github.com/nuvooo/togglely/issues"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "togglely",
    "vanilla",
    "javascript"
  ],
  "author": "Togglely",
  "license": "MIT",
  "dependencies": {
    "@togglely/sdk-core": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.60.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
