# Staging Environment Configuration
NODE_ENV=staging
PORT=4000

# Database (separate staging database!)
DATABASE_URL=mongodb://togglely:staging_secret@staging-db:27017/togglely_staging?authSource=admin
REDIS_URL=redis://staging-redis:6379

# Auth
JWT_SECRET=staging-jwt-secret-change-me
JWT_EXPIRY=7d
RESET_TOKEN_EXPIRY_HOURS=1

# CORS (staging domains only)
CORS_ORIGINS=https://staging.togglely.de

# Frontend
VITE_API_URL=https://api-staging.togglely.de/api
FRONTEND_URL=https://staging.togglely.de

# Email (use mailtrap or similar for staging)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=staging_user
SMTP_PASS=staging_pass
SMTP_FROM="Togglely Staging" <noreply@staging.togglely.de>
SMTP_SECURE=false
