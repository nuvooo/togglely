# Backend Configuration
NODE_ENV=development
PORT=4000
DATABASE_URL=mongodb://togglely:togglely_secret@localhost:27017/togglely?authSource=admin
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS Configuration (comma-separated list of allowed origins)
# For local development:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# For production with separate domains:
# CORS_ORIGINS=https://app.togglely.de,https://togglely.de,https://api.togglely.de

# Frontend Configuration
VITE_API_URL=http://localhost:4000/api
FRONTEND_URL=http://localhost:3000

# Email Configuration (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_username
SMTP_PASS=your_password
SMTP_FROM="Togglely" <noreply@togglely.com>
SMTP_SECURE=false

# For Production Setup (Coolify):
# Backend gets its own domain: https://api.togglely.de
# Frontend gets its own domain: https://app.togglely.de
# SDK should use BACKEND_URL for direct API access
